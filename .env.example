# .env.example — Template for the .env file.
# Copy this file to .env and fill in the values.

# ─── PostgreSQL ───
POSTGRES_USER=plantuml
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand
POSTGRES_DB=plantuml

# ─── Security ───
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
INTERNAL_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── OAuth — Google ───
# Create at https://console.cloud.google.com/apis/credentials
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# ─── OAuth — GitHub ───
# Create at https://github.com/settings/applications/new
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ─── Email (Resend) ───
# Get an API key at https://resend.com
RESEND_API_KEY=
EMAIL_FROM=MyApp <noreply@example.com>

# ─── Public URL ───
# The URL users access in their browser. No trailing slash.
# PUBLIC_DOMAIN is also used by nginx.conf for TLS cert paths and server_name.
PUBLIC_URL=https://app.example.com
PUBLIC_DOMAIN=app.example.com

# ─── Backup ───
BACKUP_S3_BUCKET=plantuml-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
