# .env.example — Template for the .env file.
# Copy this file to .env and fill in the values.

# ─── PostgreSQL ───
POSTGRES_USER=plantuml
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand
POSTGRES_DB=plantuml

# ─── Security ───
# Shared secret for FastAPI ↔ Hocuspocus internal endpoints.
INTERNAL_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Clerk (authentication) ───
# Identity, accounts, social login, and account recovery are handled by Clerk.
# Get these from the Clerk Dashboard → your app → API keys (use the Production
# instance for a production deploy). ISSUER/JWKS_URL use your Clerk Frontend
# API domain (clerk.<your-domain>).
CLERK_SECRET_KEY=sk_live_CHANGE_ME
CLERK_ISSUER=https://clerk.plottedplant.com
CLERK_JWKS_URL=https://clerk.plottedplant.com/.well-known/jwks.json
# Publishable key — baked into the frontend build at build time. Public/safe.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# ─── Public URL ───
# The URL users access in their browser. No trailing slash.
# PUBLIC_DOMAIN is also used by nginx.conf for TLS cert paths and server_name.
PUBLIC_URL=https://plottedplant.com
PUBLIC_DOMAIN=plottedplant.com

# ─── Backup ───
BACKUP_S3_BUCKET=plantuml-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
BACKUP_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
